<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.GbDistributerSupplierPaymentDao">

	<select id="queryObject" resultType="com.nongxinle.entity.GbDistributerSupplierPaymentEntity">
		select * from gb_distributer_supplier_payment where gb_distributer_supplier_payment_id = #{value}
	</select>

	<select id="queryList" resultType="com.nongxinle.entity.GbDistributerSupplierPaymentEntity">
		select * from gb_distributer_supplier_payment 
		<if test="offset != null and limit != null">
			limit #{offset}, #{limit}
		</if>
	</select>
	
 	<select id="queryTotal" resultType="int">
		select count(*) from gb_distributer_supplier_payment 
	</select>


	<resultMap id="dep" type="GbDepartmentEntity">
		<id property="gbDepartmentId" column="gb_department_id"/>
        <result property="gbDepartmentSubAmount" column="gb_department_sub_amount"/>
		<result property="gbDepartmentNamePy" column="gb_department_name_py"/>
		<result property="gbDepartmentName" column="gb_department_name"/>
		<result property="gbDepartmentType" column="gb_department_type"/>
		<result property="gbDepartmentSettleType" column="gb_department_settle_type"/>
		<result property="gbDepartmentIsGroupDep" column="gb_department_is_group_dep"/>
		<result property="gbDepartmentSubAmount" column="gb_department_sub_amount"/>
		<result property="gbDepartmentLevel" column="gb_department_level"/>
	</resultMap>

 <resultMap id="depUser" type="GbDepartmentUserEntity">
	 <id property="gbDepartmentUserId" column="gb_department_user_id"/>
	 <result property="gbDuLoginTimes" column="gb_DU_login_times"/>
	 <result property="gbDuDepartmentId" column="gb_DU_department_id"/>
	 <result property="gbDuCustomerService" column="gb_DU_customer_service"/>
	 <result property="gbDuWxNickName" column="gb_DU_wx_nick_name"/>
	 <result property="gbDuWxAvartraUrl" column="gb_DU_wx_avartra_url"/>
	 <result property="gbDuUrlChange" column="gb_DU_url_change"/>
	 <result property="gbDuWxOpenId" column="gb_DU_wx_open_id"/>
	 <result property="gbDuPrintDeviceId" column="gb_DU_print_device_id"/>
	 <result property="gbDuPrintBillDeviceId" column="gb_DU_print_bill_device_id"/>
	 <association property="gbDepartmentEntity" resultMap="dep"/>
  </resultMap>

	<resultMap id="jrdhSupplier" type="NxJrdhSupplierEntity">
		<id property="nxJrdhSupplierId" column="nx_jrdh_supplier_id"/>
		<result property="nxJrdhsSysCityId" column="nx_jrdhs_sys_city_id"/>
		<result property="nxJrdhsSysMarketId" column="nx_jrdhs_sys_market_id"/>
		<result property="nxJrdhsNxDistributerId" column="nx_jrdhs_nx_distributer_id"/>
		<result property="nxJrdhsGbDistributerId" column="nx_jrdhs_gb_distributer_id"/>
		<result property="nxJrdhsGbDepartmentId" column="nx_jrdhs_gb_department_id"/>
		<result property="nxJrdhsSupplierName" column="nx_jrdhs_supplier_name"/>
		<result property="nxJrdhsUserId" column="nx_jrdhs_user_id"/>
		<association property="gbPurUserEntity" resultMap="depUser"/>
	</resultMap>

	<resultMap id="nxDis" type="NxDistributerEntity">
		 <id property="nxDistributerId" column="nx_distributer_id"/>
        <result property="nxDistributerSysMarketId"  column="nx_distributer_sys_market_id"/>
        <result property="nxDistributerBuyQuantity" column="nx_distribuyter_buy_quantity"/>
        <result property="nxDistributerManager" column="nx_distributer_manager"/>
        <result property="nxDistributerMarketName" column="nx_distributer_market_name"/>
		<result property="nxDistributerPayUrl" column="nx_distributer_pay_url"/>
        <result property="nxDistributerShelfQuantity" column="nx_distributer_shelf_quantity"/>
		<result property="nxDistributerType" column="nx_distributer_type"/>
		<result property="nxDistributerName" column="nx_distributer_name"/>
	<result property="nxDistributerShowName" column="nx_distributer_show_name"/>
		<result property="nxDistributerImg" column="nx_distributer_img"/>
		<result property="nxDistributerMarketName" column="nx_distributer_market_name"/>
		<result property="nxDistributerAddress" column="nx_distributer_address"/>
		<result property="nxDistributerManager" column="nx_distributer_manager"/>
	</resultMap>


	<resultMap id="disUser" type="GbDistributerUserEntity">
		<id property="gbDistributerUserId" column="gb_distributer_user_id"/>
		<result property="gbDiuLoginTimes" column="gb_DIU_login_times"/>
		<result property="gbDiuLoginTimes" column="gb_DIU_login_times"/>
		<result property="gbDiuLoginTimes" column="gb_DIU_login_times"/>
		<result property="gbDiuQyCorpUserId" column="gb_DIU_qy_corp_user_id"/>
		<result property="gbDiuWxNickName" column="gb_DIU_wx_nick_name"/>
		<result property="gbDiuWxAvartraUrl" column="gb_DIU_wx_avartra_url"/>
		<result property="gbDiuAdmin" column="gb_DIU_admin"/>
		<result property="gbDiuUrlChange" column="gb_DIU_url_change"/>
		<result property="gbDiuPrintDeviceId" column="gb_DIU_print_device_id"/>
	</resultMap>
	<resultMap id="payment" type="GbDistributerSupplierPaymentEntity">
		<id property="gbDistributerSupplierPaymentId" column="gb_distributer_supplier_payment_id"/>
		<result property="gbDspDate" column="gb_dsp_date"/>
		<result property="gbDspPayUserId" column="gb_dsp_pay_user_id"/>
		<result property="gbDspPayTotal" column="gb_dsp_pay_total"/>
		<result property="gbDspSupplierId" column="gb_dsp_supplier_id"/>
		<result property="gbDspNxDistributerId" column="gb_dsp_nx_distributer_id"/>
		<result property="gbDspDistributerId" column="gb_dsp_distributer_id"/>
		<result property="gbDspWxOutTradeNo" column="gb_dsp_wx_out_trade_no"/>
		<result property="gbDspStatus" column="gb_dsp_status"/>
		<association property="jrdhSupplierEntity" resultMap="jrdhSupplier"/>
		<association property="nxDistributerEntity" resultMap="nxDis"/>
		<association property="payUserEntity" resultMap="disUser"/>

	</resultMap>


    <select id="queryPaymentListByParams" resultMap="payment">
      select * from gb_distributer_supplier_payment as gdsp
      left join gb_distributer_supplier as sup on sup.gb_distributer_supplier_id = gdsp.gb_dsp_distributer_id
      left join nx_distributer as nd  on nd.nx_distributer_id = gdsp.gb_dsp_nx_distributer_id
       left join nx_jrdh_supplier as njs on njs.nx_jrdh_supplier_id = gdsp.gb_dsp_supplier_id
       left join gb_distributer_user as gdu on gdu.gb_distributer_user_id = gdsp.gb_dsp_pay_user_id
        left join gb_department_user   as purUser on purUser.gb_department_user_id = njs.nx_jrdhs_gb_pur_user_id
		left join gb_department as gd on gd.gb_department_id = purUser.gb_DU_department_id

		<where>
		   <if test="disId != null">
			   and gb_dsp_distributer_id = #{disId}
		   </if>

	   </where>
	</select>
	<select id="queryPaymentByWxTradeNo" resultType="com.nongxinle.entity.GbDistributerSupplierPaymentEntity">
		select * from gb_distributer_supplier_payment gdsp
			where gdsp.gb_dsp_wx_out_trade_no = #{ordersSn}
	</select>

	<insert id="save" parameterType="com.nongxinle.entity.GbDistributerSupplierPaymentEntity"
	useGeneratedKeys="true" keyProperty="gbDistributerSupplierPaymentId">
		insert into gb_distributer_supplier_payment
		(
			`gb_distributer_supplier_payment_id`, 
			`gb_dsp_date`, 
			`gb_dsp_supplier_id`, 
			`gb_dsp_pay_user_id`, 
			`gb_dsp_pay_total`,
		 	`gb_dsp_distributer_id`,
		 	`gb_dsp_nx_distributer_id`,
		 	`gb_dsp_wx_out_trade_no`,
		 	`gb_dsp_status`,
		 	`gb_dsp_pay_full_time`
		)
		values
		(
			#{gbDistributerSupplierPaymentId}, 
			#{gbDspDate}, 
			#{gbDspSupplierId}, 
			#{gbDspPayUserId}, 
			#{gbDspPayTotal},
			#{gbDspDistributerId},
			#{gbDspNxDistributerId},
			#{gbDspWxOutTradeNo},
			#{gbDspStatus},
			#{gbDspPayFullTime}
		)
	</insert>
	 
	<update id="update" parameterType="com.nongxinle.entity.GbDistributerSupplierPaymentEntity">
		update gb_distributer_supplier_payment 
		<set>
			<if test="gbDspDate != null">`gb_dsp_date` = #{gbDspDate}, </if>
			<if test="gbDspSupplierId != null">`gb_dsp_supplier_id` = #{gbDspSupplierId}, </if>
			<if test="gbDspPayUserId != null">`gb_dsp_pay_user_id` = #{gbDspPayUserId}, </if>
			<if test="gbDspDistributerId != null">`gb_dsp_distributer_id` = #{gbDspDistributerId}, </if>
			<if test="gbDspNxDistributerId != null">`gb_dsp_nx_distributer_id` = #{gbDspNxDistributerId}, </if>
			<if test="gbDspWxOutTradeNo != null">`gb_dsp_wx_out_trade_no` = #{gbDspWxOutTradeNo}, </if>
			<if test="gbDspStatus != null">`gb_dsp_status` = #{gbDspStatus}, </if>
			<if test="gbDspPayFullTime != null">`gb_dsp_pay_full_time` = #{gbDspPayFullTime}, </if>
			<if test="gbDspPayTotal != null">`gb_dsp_pay_total` = #{gbDspPayTotal}</if>
		</set>
		where gb_distributer_supplier_payment_id = #{gbDistributerSupplierPaymentId}
	</update>
	
	<delete id="delete">
		delete from gb_distributer_supplier_payment where gb_distributer_supplier_payment_id = #{value}
	</delete>
	
	<delete id="deleteBatch">
		delete from gb_distributer_supplier_payment where gb_distributer_supplier_payment_id in 
		<foreach item="gbDistributerSupplierPaymentId" collection="array" open="(" separator="," close=")">
			#{gbDistributerSupplierPaymentId}
		</foreach>
	</delete>

</mapper>