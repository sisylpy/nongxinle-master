<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.NxMarketDepartmentDao">

    <select id="queryObject" resultType="com.nongxinle.entity.NxMarketDepartmentEntity">
        select * from nx_market_department where nx_market_department_id = #{value}
    </select>

    <select id="queryActiveByMarketAndDepartment" resultType="com.nongxinle.entity.NxMarketDepartmentEntity">
        select * from nx_market_department
        where nx_md_market_id = #{param1}
          and nx_md_department_id = #{param2}
          and nx_md_status = 'ACTIVE'
        limit 1
    </select>

    <select id="queryActiveListByMarketId" resultType="com.nongxinle.entity.NxMarketDepartmentEntity">
        select * from nx_market_department
        where nx_md_market_id = #{value}
          and nx_md_status = 'ACTIVE'
        order by nx_md_department_id asc
    </select>

    <insert id="save" parameterType="com.nongxinle.entity.NxMarketDepartmentEntity"
            useGeneratedKeys="true" keyProperty="nxMarketDepartmentId">
        insert into nx_market_department
        (`nx_md_market_id`, `nx_md_department_id`, `nx_md_status`, `nx_md_source`, `nx_md_created_by`)
        values
        (#{nxMdMarketId}, #{nxMdDepartmentId}, #{nxMdStatus}, #{nxMdSource}, #{nxMdCreatedBy})
    </insert>
</mapper>
