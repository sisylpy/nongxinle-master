	<select id="queryShelfForGoodsWithOrders" resultMap="shelfGoodsWithOrders">
		select * from (
		select distinct
		ndgsg.nx_distributer_goods_shelf_goods_id,
		ndgsg.nx_DGSG_shelf_sort,
		ndgsg.nx_DGSG_sort
		from nx_distributer_goods_shelf_goods as ndgsg
		inner join nx_department_orders as dor on dor.nx_DO_dis_goods_id = ndgsg.nx_DGSG_dis_goods_id
		<where>
			<if test="shelfId != null">
				and ndgsg.nx_DGSG_shelf_id = #{shelfId}
			</if>
			<if test="disId != null">
				and dor.nx_DO_distributer_id = #{disId}
			</if>
			<if test="status != null">
				and dor.nx_DO_status &lt; #{status}
			</if>
			<if test="purStatus != null">
				and dor.nx_DO_purchase_status &lt; #{purStatus}
			</if>
		</where>
		order by ndgsg.nx_DGSG_shelf_sort, ndgsg.nx_DGSG_sort
		<if test="offset != null and limit != null">
			limit #{offset}, #{limit}
		</if>
		) as t1
		inner join nx_distributer_goods_shelf_goods as ndgsg on ndgsg.nx_distributer_goods_shelf_goods_id = t1.nx_distributer_goods_shelf_goods_id
		inner join nx_department_orders as dor on dor.nx_DO_dis_goods_id = ndgsg.nx_DGSG_dis_goods_id
		left join nx_department as nds on nds.nx_department_id = dor.nx_DO_department_id
		left join nx_department as ndf on ndf.nx_department_id = nds.nx_department_father_id
		left join gb_department as ngds on ngds.gb_department_id = dor.nx_DO_gb_department_id
		left join gb_department as ngdf on ngdf.gb_department_id = dor.nx_DO_gb_department_father_id
		left join nx_restraunt as ndnr on ndnr.nx_restraunt_id = dor.nx_DO_nx_comm_restraunt_id
		left join nx_distributer_goods as ndg on ndg.nx_distributer_goods_id = dor.nx_DO_dis_goods_id
		left join nx_distributer_goods_shelf_stock as ndgss on ndgss.nx_dgss_nx_dis_goods_id = ndg.nx_distributer_goods_id
		left join nx_department_dis_goods as nddg on nddg.nx_DDG_dis_goods_id = ndg.nx_distributer_goods_id
		and nddg.nx_DDG_gb_department_id = dor.nx_DO_gb_department_id
		order by t1.nx_DGSG_shelf_sort, t1.nx_DGSG_sort
	</select>

