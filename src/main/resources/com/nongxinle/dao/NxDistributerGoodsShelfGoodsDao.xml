<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.NxDistributerGoodsShelfGoodsDao">

    <select id="queryObject" resultType="com.nongxinle.entity.NxDistributerGoodsShelfGoodsEntity">
        select *
        from nx_distributer_goods_shelf_goods
        where nx_distributer_goods_shelf_goods_id = #{value}
    </select>

    <select id="queryList" resultType="com.nongxinle.entity.NxDistributerGoodsShelfGoodsEntity">
        select * from nx_distributer_goods_shelf_goods
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>

    <select id="queryTotal" resultType="int">
        select count(*)
        from nx_distributer_goods_shelf_goods
    </select>

    <select id="queryShelfForGoodsByParams" resultMap="shelfGoods">
        select * from nx_distributer_goods_shelf_goods as ndgsg
        left join nx_distributer_goods as ndg on ndg.nx_distributer_goods_id = ndgsg.nx_DGSG_dis_goods_id
        <where>
            <if test="shelfId !=null">
                and nx_DGSG_shelf_id = #{shelfId}
            </if>
            <if test="dayuSort !=null">
                and nx_DGSG_sort &gt; #{dayuSort}
            </if>
            <if test="disGoodsId !=null">
                and nx_DGSG_dis_goods_id = #{disGoodsId}
            </if>
        </where>
    </select>

    <select id="queryShelfGoodsCount" resultType="java.lang.Integer">
        select COUNT(DISTINCT ndgsg.nx_distributer_goods_shelf_goods_id)
        from nx_distributer_goods_shelf_goods as ndgsg
        inner join nx_department_orders as dor on dor.nx_DO_dis_goods_id = ndgsg.nx_DGSG_dis_goods_id
        <where>
            <if test="shelfId != null and shelfId == 0">
                and ndgsg.nx_DGSG_dis_goods_id is null
            </if>
            <if test="shelfId != null and shelfId == 1">
                and ndgsg.nx_DGSG_dis_goods_id is not null
            </if>
            <if test="disId != null">
                and dor.nx_DO_distributer_id = #{disId}
            </if>
            <if test="status != null">
                and dor.nx_DO_status &lt; #{status}
            </if>
            <if test="purStatus != null">
                and dor.nx_DO_purchase_status &lt; #{purStatus}
            </if>
        </where>
    </select>

