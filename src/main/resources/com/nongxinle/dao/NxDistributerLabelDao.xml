<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.NxDistributerLabelDao">

    <select id="queryObject" resultType="com.nongxinle.entity.NxDistributerLabelEntity">
        select *
        from nx_distributer_label
        where nx_distributer_label_id = #{value}
    </select>

    <select id="queryList" resultType="com.nongxinle.entity.NxDistributerLabelEntity">
        select *
        from nx_distributer_label
        <if test="offset != null and limit != null">
            limit #{offset}, #{limit}
        </if>
    </select>

    <select id="queryTotal" resultType="int">
        select count(*)
        from nx_distributer_label
    </select>

    <insert id="save" parameterType="com.nongxinle.entity.NxDistributerLabelEntity"
            useGeneratedKeys="true" keyProperty="nxDistributerLabelId">
        insert into nx_distributer_label
        (
        `nx_distributer_label_id`,
        `nx_dl_distributer_id`,
        `nx_dl_name`,
        `nx_dl_sort`,
        `nx_dl_status`
        )
        values
        (
        #{nxDistributerLabelId},
        #{nxDlDistributerId},
        #{nxDlName},
        #{nxDlSort},
        #{nxDlStatus}
        )
    </insert>

    <update id="update" parameterType="com.nongxinle.entity.NxDistributerLabelEntity">
        update nx_distributer_label
        <set>
            <if test="nxDlDistributerId != null">`nx_dl_distributer_id` = #{nxDlDistributerId},</if>
            <if test="nxDlName != null">`nx_dl_name` = #{nxDlName},</if>
            <if test="nxDlSort != null">`nx_dl_sort` = #{nxDlSort},</if>
            <if test="nxDlStatus != null">`nx_dl_status` = #{nxDlStatus}</if>
        </set>
        where nx_distributer_label_id = #{nxDistributerLabelId}
    </update>

    <delete id="delete">
        delete from nx_distributer_label
        where nx_distributer_label_id = #{value}
    </delete>

    <delete id="deleteBatch">
        delete from nx_distributer_label where nx_distributer_label_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="queryLabelsByDisId" resultType="com.nongxinle.entity.NxDistributerLabelEntity">
        select *
        from nx_distributer_label
        where nx_dl_distributer_id = #{disId}
          and (nx_dl_status is null or nx_dl_status = 1)
        order by nx_dl_sort asc, nx_distributer_label_id desc
    </select>

    <delete id="deleteByDisId">
        delete from nx_distributer_label
        where nx_dl_distributer_id = #{disId}
    </delete>

    <select id="queryByDisIdAndName" resultType="com.nongxinle.entity.NxDistributerLabelEntity">
        select *
        from nx_distributer_label
        where nx_dl_distributer_id = #{disId}
          and nx_dl_name = #{name}
        limit 1
    </select>
</mapper>
