<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.PlatformCheckoutPaymentDao">

    <select id="queryObject" resultType="com.nongxinle.entity.PlatformCheckoutPaymentEntity">
        select * from platform_checkout_payment where pcp_id = #{value}
    </select>

    <select id="queryByCheckoutToken" resultType="com.nongxinle.entity.PlatformCheckoutPaymentEntity">
        select * from platform_checkout_payment where pcp_checkout_token = #{value}
    </select>

    <select id="queryByOutTradeNo" resultType="com.nongxinle.entity.PlatformCheckoutPaymentEntity">
        select * from platform_checkout_payment where pcp_out_trade_no = #{value}
    </select>

    <select id="queryList" resultType="com.nongxinle.entity.PlatformCheckoutPaymentEntity">
        select * from platform_checkout_payment
        <where>
            <if test="gbDepartmentId != null">and pcp_gb_department_id = #{gbDepartmentId}</if>
            <if test="status != null">and pcp_status = #{status}</if>
        </where>
        order by pcp_id desc
    </select>

    <select id="queryPendingByGbDepartmentId" resultType="com.nongxinle.entity.PlatformCheckoutPaymentEntity">
        select * from platform_checkout_payment
        where pcp_gb_department_id = #{value}
          and pcp_status = 'PENDING'
        order by pcp_id desc
    </select>

    <insert id="save" parameterType="com.nongxinle.entity.PlatformCheckoutPaymentEntity"
            useGeneratedKeys="true" keyProperty="pcpId">
        insert into platform_checkout_payment
        (`pcp_checkout_token`, `pcp_market_id`, `pcp_gb_department_id`, `pcp_gb_department_father_id`,
         `pcp_gb_distributer_id`, `pcp_gb_order_user_id`, `pcp_delivery_date`, `pcp_remark`,
         `pcp_order_ids_json`, `pcp_known_total`, `pcp_pending_price_item_count`, `pcp_out_trade_no`,
         `pcp_wx_prepay_id`, `pcp_open_id`, `pcp_status`, `pcp_bill_id`, `pcp_transaction_id`,
         `pcp_notify_raw`, `pcp_paid_at`, `pcp_expire_at`, `pcp_closed_at`, `pcp_created_at`, `pcp_updated_at`)
        values
        (#{pcpCheckoutToken}, #{pcpMarketId}, #{pcpGbDepartmentId}, #{pcpGbDepartmentFatherId},
         #{pcpGbDistributerId}, #{pcpGbOrderUserId}, #{pcpDeliveryDate}, #{pcpRemark},
         #{pcpOrderIdsJson}, #{pcpKnownTotal}, #{pcpPendingPriceItemCount}, #{pcpOutTradeNo},
         #{pcpWxPrepayId}, #{pcpOpenId}, #{pcpStatus}, #{pcpBillId}, #{pcpTransactionId},
         #{pcpNotifyRaw}, #{pcpPaidAt}, #{pcpExpireAt}, #{pcpClosedAt}, #{pcpCreatedAt}, #{pcpUpdatedAt})
    </insert>

    <update id="update" parameterType="com.nongxinle.entity.PlatformCheckoutPaymentEntity">
        update platform_checkout_payment
        <set>
            <if test="pcpWxPrepayId != null">`pcp_wx_prepay_id` = #{pcpWxPrepayId},</if>
            <if test="pcpStatus != null">`pcp_status` = #{pcpStatus},</if>
            <if test="pcpBillId != null">`pcp_bill_id` = #{pcpBillId},</if>
            <if test="pcpTransactionId != null">`pcp_transaction_id` = #{pcpTransactionId},</if>
            <if test="pcpNotifyRaw != null">`pcp_notify_raw` = #{pcpNotifyRaw},</if>
            <if test="pcpPaidAt != null">`pcp_paid_at` = #{pcpPaidAt},</if>
            <if test="pcpExpireAt != null">`pcp_expire_at` = #{pcpExpireAt},</if>
            <if test="pcpClosedAt != null">`pcp_closed_at` = #{pcpClosedAt},</if>
            <if test="pcpUpdatedAt != null">`pcp_updated_at` = #{pcpUpdatedAt},</if>
        </set>
        where pcp_id = #{pcpId}
    </update>

    <update id="finalizeSuccessIfPending" parameterType="com.nongxinle.entity.PlatformCheckoutPaymentEntity">
        update platform_checkout_payment
        set pcp_status = #{pcpStatus},
            pcp_bill_id = #{pcpBillId},
            pcp_transaction_id = #{pcpTransactionId},
            pcp_notify_raw = #{pcpNotifyRaw},
            pcp_paid_at = #{pcpPaidAt},
            pcp_updated_at = #{pcpUpdatedAt}
        where pcp_id = #{pcpId}
          and pcp_status = 'PENDING'
    </update>

    <update id="closeIfPending" parameterType="com.nongxinle.entity.PlatformCheckoutPaymentEntity">
        update platform_checkout_payment
        set pcp_status = #{pcpStatus},
            pcp_closed_at = #{pcpClosedAt},
            pcp_updated_at = #{pcpUpdatedAt}
        where pcp_id = #{pcpId}
          and pcp_status = 'PENDING'
    </update>

    <delete id="delete">
        delete from platform_checkout_payment where pcp_id = #{value}
    </delete>
</mapper>
