			<if test="gbDistributerBuyQuantity != null">`gb_distributer_buy_quantity` = #{gbDistributerBuyQuantity}, </if>
			<if test="gbDistributerSysCityId != null">`gb_distributer_sys_city_id` = #{gbDistributerSysCityId}, </if>
