	<delete id="delete">
		delete from nx_distributer_coupon where nx_distributer_coupon_id = #{value}
	</delete>
	
	<delete id="deleteBatch">
		delete from nx_distributer_coupon where nx_distributer_coupon_id in 
		<foreach item="nxDistributerCouponId" collection="array" open="(" separator="," close=")">
			#{nxDistributerCouponId}
		</foreach>
	</delete>

</mapper>