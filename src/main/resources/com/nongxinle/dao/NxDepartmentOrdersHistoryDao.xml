	<select id="queryLogs" resultType="java.util.Map">
		SELECT nx_DOH_apply_date, nx_DOH_quantity
		FROM nx_department_orders_history
		<where>
			<if test="depFatherId != null">
				AND nx_DOH_department_father_id = #{depFatherId}
			</if>
			<if test="depId != null">
				AND nx_DOH_department_id = #{depId}
			</if>
			<if test="disGoodsId != null">
				AND nx_DOH_dis_goods_id = #{disGoodsId}
			</if>
			LIMIT 3
		</where>


	</select>

		<!-- 5.1 过去 days 天内，下单次数 ≥ minTimes 的商品 -->
		<select id="selectFrequentGoods" resultType="java.lang.Integer">
			SELECT nx_DOH_dis_goods_id
			FROM nx_department_orders_history
			WHERE nx_DOH_department_id = #{depId}
			  AND nx_DOH_apply_date >= CURDATE() - INTERVAL #{windowDays} DAY
			GROUP BY nx_DOH_dis_goods_id
			HAVING COUNT(*) >= #{minTimes} order by nx_DOH_dis_goods_id
		</select>

	<!-- 5.2 过去 days 天内每天平均用量 -->
	<select id="selectAvgDaily" resultType="com.nongxinle.entity.AvgDaily">
		SELECT
		nx_DOH_dis_goods_id AS goodsId,
		SUM(nx_DOH_quantity) / #{days} AS avgDailyQty
		FROM nx_department_orders_history
		WHERE nx_DOH_department_id = #{depId}
		AND nx_DOH_dis_goods_id IN
		<foreach item="gid" collection="goodsIds" open="(" separator="," close=")">
			#{gid}
		</foreach>
		AND nx_DOH_apply_date >= CURDATE() - INTERVAL #{days} DAY
		GROUP BY nx_DOH_dis_goods_id
	</select>


	<!-- 5.3 每个商品最近一次订货 -->
	<select id="selectLastOrders" parameterType="map" resultType="com.nongxinle.entity.NxDepartmentOrdersHistoryEntity">
		SELECT
		t.nxDohDisGoodsId  AS nxDohDisGoodsId,
		t.nxDohQuantity    AS nxDohQuantity,
		t.nxDohApplyDate   AS nxDohApplyDate
		FROM (
		SELECT
		nx_DOH_dis_goods_id  AS nxDohDisGoodsId,
		nx_DOH_quantity      AS nxDohQuantity,
		nx_DOH_apply_date    AS nxDohApplyDate,
		ROW_NUMBER() OVER (
		PARTITION BY nx_DOH_dis_goods_id
		ORDER BY nx_DOH_apply_date DESC
		) AS rn
		FROM nx_department_orders_history
		WHERE nx_DOH_department_id = #{depId}
		AND nx_DOH_dis_goods_id IN
		<foreach item="gid" collection="goodsIds" open="(" separator="," close=")">
			#{gid}
		</foreach>
		) t
		WHERE t.rn = 1
	</select>

