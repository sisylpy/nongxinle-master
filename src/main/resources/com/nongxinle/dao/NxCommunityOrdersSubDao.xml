    <select id="querySubOrdersByParams" resultMap="subOrders">
        select *,
        ncgsiGoods.nx_community_goods_set_item_id 'goods_nx_community_goods_set_item_id',
        ncgsiGoods.nx_cgsi_item_name 'goods_nx_cgsi_item_name',
        ncgsiGoods.nx_cgsi_item_status 'goods_nx_cgsi_item_status',
        ncgsiGoods.nx_cgsi_item_cg_goods_id 'goods_nx_cgsi_item_cg_goods_id',
        ncgsiGoods.nx_cgsi_item_type 'goods_nx_cgsi_item_type',
        ncgsiGoods.nx_cgsi_item_file_path 'goods_nx_cgsi_item_file_path',
        ncgsiGoods.nx_cgsi_item_price 'goods_nx_cgsi_item_price',
        ncgsiGoods.nx_cgsi_item_quantity 'goods_nx_cgsi_item_quantity'
        from nx_community_orders_sub  as s
          left join nx_community_goods as cg on s.nx_COS_community_goods_id = cg.nx_community_goods_id
           left join nx_community_card as ncc on ncc.nx_community_card_id = cg.nx_cg_card_id
        left join nx_customer_user_card as ncuc on ncuc.nx_cuca_customer_user_id = s.nx_COS_order_user_id and ncuc.nx_cuca_status = 1
            and ncuc.nx_cuca_card_id = ncc.nx_community_card_id
        left join nx_community_goods_set_item as ncgsiGoods on ncgsiGoods.nx_cgsi_item_cg_goods_id = cg.nx_community_goods_id
        and ncgsiGoods.nx_cgsi_item_status  &gt; -1
        <where>
            <if test="fatherId != null">
              and  nx_COS_community_goods_father_id = #{fatherId}
            </if>
            <if test="goodsId != null">
                and  nx_COS_community_goods_id = #{goodsId}
            </if>
            <if test="orderId != null">
                and  nx_COS_orders_id = #{orderId}
            </if>
            <if test="splicingOrderId != null">
                and  s.nx_COS_splicing_orders_id = #{splicingOrderId}
            </if>
            <if test="orderUserId != null">
                and  nx_COS_order_user_id = #{orderUserId}
            </if>
            <if test="deskId != null">
                and  nx_COS_desk_id = #{deskId}
            </if>
            <if test="orderType != null">
                and  s.nx_COS_type = #{orderType}
            </if>
            <if test="serviceType != null">
                and  s.nx_COS_service_type = #{serviceType}
            </if>
            <if test="diffPrice != null">
                and  s.nx_COS_huaxian_different_price =  #{diffPrice}
            </if>
            <if test="dayuDiffPrice != null">
                and  s.nx_COS_huaxian_different_price &gt;  #{dayuDiffPrice}
            </if>
            <if test="xiaoyuStatus != null">
                and  s.nx_COS_status &lt; #{xiaoyuStatus}
            </if>
            <if test="dayuStatus != null">
                and  s.nx_COS_status &gt; #{dayuStatus}
            </if>
            <if test="status != null">
                and  s.nx_COS_status =  #{status}
            </if>
            <if test="cardId != null">
                and  cg.nx_cg_card_id =  #{cardId}
            </if>
        </where>
    </select>
    <select id="queryPrintSubOrders" resultMap="printSubOrders">
        select * from nx_community_orders_sub  as s
        left join nx_community_goods as cg on s.nx_COS_community_goods_id = cg.nx_community_goods_id

        <where>
            <if test="commId != null">
                and  nx_COS_community_id = #{commId}
            </if>
            <if test="fatherId != null">
                and  nx_COS_community_goods_father_id = #{fatherId}
            </if>
            <if test="goodsId != null">
                and  nx_COS_community_goods_id = #{goodsId}
            </if>
            <if test="orderId != null">
                and  nx_COS_orders_id = #{orderId}
            </if>
            <if test="orderUserId != null">
                and  nx_COS_order_user_id = #{orderUserId}
            </if>
            <if test="deskId != null">
                and  nx_COS_desk_id = #{deskId}
            </if>
            <if test="type != null">
                and  s.nx_COS_type = #{type}
            </if>
            <if test="status != null">
                and  s.nx_COS_status =  #{status}
            </if>
            <if test="xiaoyuType != null">
                and  s.nx_COS_type &lt; #{xiaoyuType}
            </if>
            <if test="dayuType != null">
                and  s.nx_COS_type &gt; #{dayuType}
            </if>
            <if test="xiaoyuStatus != null">
                and  s.nx_COS_status &lt; #{xiaoyuStatus}
            </if>
            <if test="dayuStatus != null">
                and  s.nx_COS_status &gt; #{dayuStatus}
            </if>

            <if test="service != null">
                and  s.nx_COS_service =  #{service}
            </if>
            <if test="time != null">
                and  s.nx_COS_service_time &lt;  #{time}
            </if>
            <if test="date != null">
                and  s.nx_COS_service_date =  #{date}
            </if>
        </where>
         limit 1
    </select>

