<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.NxDisDriverDutyDao">

    <select id="queryByDisDriverDate" resultType="com.nongxinle.entity.NxDisDriverDutyEntity">
        select * from nx_dis_driver_duty
        where nx_ddd_distributer_id = #{disId}
          and nx_ddd_driver_user_id = #{driverUserId}
          and nx_ddd_duty_date = #{dutyDate}
        limit 1
    </select>

    <select id="queryOnDutyDrivers" resultType="com.nongxinle.dto.route.DriverAvailableDto">
        select u.nx_distributer_user_id as driverUserId,
               u.nx_DIU_wx_nick_name    as driverName,
               u.nx_DIU_wx_phone        as driverPhone,
               d.nx_ddd_duty_status     as dutyStatus,
               d.nx_ddd_duty_date       as dutyDate
        from nx_dis_driver_duty d
                 inner join nx_distributer_user u
                            on u.nx_distributer_user_id = d.nx_ddd_driver_user_id
        where d.nx_ddd_distributer_id = #{disId}
          and d.nx_ddd_duty_date = #{dutyDate}
          and d.nx_ddd_duty_status = 'ON_DUTY'
          and u.nx_DIU_admin = 5
        order by u.nx_distributer_user_id
    </select>

    <insert id="save" parameterType="com.nongxinle.entity.NxDisDriverDutyEntity"
            useGeneratedKeys="true" keyProperty="nxDddId">
        insert into nx_dis_driver_duty
        (`nx_ddd_distributer_id`, `nx_ddd_driver_user_id`, `nx_ddd_duty_date`, `nx_ddd_duty_status`,
         `nx_ddd_check_in_at`, `nx_ddd_check_out_at`, `nx_ddd_operator_user_id`, `nx_ddd_updated_at`)
        values
        (#{nxDddDistributerId}, #{nxDddDriverUserId}, #{nxDddDutyDate}, #{nxDddDutyStatus},
         #{nxDddCheckInAt}, #{nxDddCheckOutAt}, #{nxDddOperatorUserId}, #{nxDddUpdatedAt})
    </insert>

    <update id="update" parameterType="com.nongxinle.entity.NxDisDriverDutyEntity">
        update nx_dis_driver_duty
        <set>
            <if test="nxDddDutyStatus != null">`nx_ddd_duty_status` = #{nxDddDutyStatus},</if>
            <if test="nxDddCheckInAt != null">`nx_ddd_check_in_at` = #{nxDddCheckInAt},</if>
            <if test="nxDddCheckOutAt != null">`nx_ddd_check_out_at` = #{nxDddCheckOutAt},</if>
            <if test="nxDddOperatorUserId != null">`nx_ddd_operator_user_id` = #{nxDddOperatorUserId},</if>
            <if test="nxDddUpdatedAt != null">`nx_ddd_updated_at` = #{nxDddUpdatedAt},</if>
        </set>
        where nx_ddd_id = #{nxDddId}
    </update>
</mapper>
