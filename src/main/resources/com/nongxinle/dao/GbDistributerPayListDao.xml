			`gb_ndpl_pay_subtotal`, 
			`gb_ndpl_pay_time`, 
			`gb_ndpl_type`, 
			`gb_ndpl_status`, 
			`gb_ndpl_pay_date`, 
			`gb_ndpl_gb_pb_id`, 
			`gb_ndpl_pay_month`, 
			`gb_ndpl_pay_year`, 
			`gb_ndpl_rest_points`, 
			`gb_ndpl_nx_supplier_id`,
			`gb_ndpl_gb_department_father_id`,
			`gb_ndpl_gb_department_id`,
			`gb_ndpl_gb_dis_goods_id`
		)
		values
		(
			#{gbDistributerPayListId}, 
			#{gbNdplGbDisId}, 
			#{gbNdplPaySubtotal}, 
			#{gbNdplPayTime}, 
			#{gbNdplType}, 
			#{gbNdplStatus}, 
			#{gbNdplPayDate}, 
			#{gbNdplGbPbId}, 
			#{gbNdplPayMonth}, 
			#{gbNdplPayYear}, 
			#{gbNdplRestPoints}, 
			#{gbNdplNxSupplierId},
			#{gbNdplGbDepartmentFatherId},
			#{gbNdplGbDepartmentId},
			#{gbNdplGbDisGoodsId}
		)
	</insert>
	 
