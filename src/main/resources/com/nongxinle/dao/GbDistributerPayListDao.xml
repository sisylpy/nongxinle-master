	<select id="queryPayListListByParams" resultMap="payDetail">
		select
		gd.*,
		ndpl.*,
		nd.*,
		njs.*,
		nju.*,
		nd_father.gb_department_id  'df_gb_department_id',
		nd_father.gb_department_name  'df_gb_department_name',
		-- 根据 type 动态选择显示内容
		CASE
		WHEN ndpl.gb_ndpl_type = 0 THEN '订货'  -- 订货显示供货商
		WHEN ndpl.gb_ndpl_type = 1 THEN '语音'  -- 语音显示客户
		WHEN ndpl.gb_ndpl_type = 2 THEN '商品'  -- 商品显示客户
		END as display_type,
		-- 客户信息（只有当 gb_department_id 不为空时才关联）
		CASE
		WHEN ndpl.gb_ndpl_gb_department_id IS NOT NULL THEN nd.gb_department_attr_name
		ELSE NULL
		END as customer_name,
		CASE
		WHEN ndpl.gb_ndpl_gb_department_id IS NOT NULL AND nd.gb_department_father_id IS NOT NULL
		THEN nd_father.gb_department_attr_name
		ELSE NULL
		END as customer_parent_name
		from gb_distributer_pay_list as ndpl
		-- 供应商关联（所有 type 都需要）
		left join nx_jrdh_supplier as njs on njs.nx_jrdh_supplier_id = ndpl.gb_ndpl_nx_supplier_id
		left join nx_jrdh_user as nju on nju.nx_jrdh_user_id = njs.nx_jrdhs_user_id
		-- 客户关联（只有当 gb_department_id 不为空时才关联）
		left join gb_department as nd on nd.gb_department_id = ndpl.gb_ndpl_gb_department_id
		left join gb_department as nd_father on nd_father.gb_department_id = nd.gb_department_father_id
		left join gb_distributer_goods as gd on gd.gb_distributer_goods_id = ndpl.gb_ndpl_gb_dis_goods_id

		<where>
			<if test="disId != null">
				and ndpl.gb_ndpl_gb_dis_id = #{disId}
			</if>
			<if test="type != null">
				and ndpl.gb_ndpl_type = #{type}
			</if>
		</where>
		order by ndpl.gb_distributer_pay_list_id DESC
		limit #{offset}, #{limit}
	</select>

