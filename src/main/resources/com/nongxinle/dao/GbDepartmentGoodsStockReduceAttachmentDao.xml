			`gb_dgsra_status`,
			`gb_dgsra_file_large_path`,
			`gb_dgsra_type`,
			`gb_dgsra_nx_supplier_id`,
			`gb_dgsra_nx_distributer_id`,
			`gb_dgsra_stars`
		)
		values
		(
			#{gbDepartmentGoodsStockReduceAttachId}, 
			#{gbDgsraGbDgsrId}, 
			#{gbDgsraContent}, 
			#{gbDgsraFilePath}, 
			#{gbDgsraStatus},
			#{gbDgsraFileLargePath},
			#{gbDgsraType},
			#{gbDgsraNxSupplierId},
			#{gbDgsraNxDistributerId},
			#{gbDgsraStars}
		)
	</insert>
	 
	<update id="update" parameterType="com.nongxinle.entity.GbDepartmentGoodsStockReduceAttachmentEntity">
		update gb_department_goods_stock_reduce_attachment 
		<set>
			<if test="gbDgsraGbDgsrId != null">`gb_dgsra_gb_dgsr_id` = #{gbDgsraGbDgsrId}, </if>
			<if test="gbDgsraContent != null">`gb_dgsra_content` = #{gbDgsraContent}, </if>
			<if test="gbDgsraFilePath != null">`gb_dgsra_file_path` = #{gbDgsraFilePath}, </if>
			<if test="gbDgsraFileLargePath != null">`gb_dgsra_file_large_path` = #{gbDgsraFileLargePath}, </if>
			<if test="gbDgsraType != null">`gb_dgsra_type` = #{gbDgsraType}, </if>
			<if test="gbDgsraNxSupplierId != null">`gb_dgsra_nx_supplier_id` = #{gbDgsraNxSupplierId}, </if>
			<if test="gbDgsraNxDistributerId != null">`gb_dgsra_nx_distributer_id` = #{gbDgsraNxDistributerId}, </if>
			<if test="gbDgsraStars != null">`gb_dgsra_stars` = #{gbDgsraStars}, </if>
			<if test="gbDgsraStatus != null">`gb_dgsra_status` = #{gbDgsraStatus}</if>
		</set>
		where gb_department_goods_stock_reduce_attach_id = #{gbDepartmentGoodsStockReduceAttachId}
	</update>
	
