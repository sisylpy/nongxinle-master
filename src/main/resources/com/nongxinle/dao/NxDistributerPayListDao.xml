			`nx_ndpl_nx_department_id`,
			`nx_ndpl_gb_department_father_id`,
			`nx_ndpl_gb_department_id`
		)
		values
		(
			#{nxDistributerPayListId}, 
			#{nxNdplNxDisId}, 
			#{nxNdplPaySubtotal}, 
