	<select id="queryPayListListByParams" resultMap="payDetail">
		select *,
		d.nx_department_id                'd_nx_department_id',
		d.nx_department_points            'd_nx_department_points',
		d.nx_department_waiting_points    'd_nx_department_waiting_points',
		d.nx_department_name              'd_nx_department_name',
		d.nx_department_attr_name              'd_nx_department_attr_name',
		d.nx_department_settle_type       'd_nx_department_settle_type',
		d.nx_department_father_id         'd_nx_department_father_id',
		d.nx_department_is_group_dep      'd_nx_department_is_group_dep',
		d.nx_department_dis_id            'd_nx_department_dis_id',
		d.nx_department_show_weeks        'd_nx_department_show_weeks',
		d.nx_department_sub_amount        'd_nx_department_sub_amount',
		d.nx_department_type              'd_nx_department_type',
		d.nx_department_type              'd_nx_department_type',
		d.nx_department_print_name        'd_nx_department_print_name',
		d.nx_department_working_status    'd_nx_department_working_status',
		d.nx_department_dis_id             'd_nx_department_dis_id',
		d.nx_department_join_date          'd_nx_department_join_date',
		d.nx_department_order_total        'd_nx_department_order_total',
		d.nx_department_pinyin             'd_nx_department_pinyin',
		subsd.nx_department_id            'subs_nx_department_id',
		subsd.nx_department_name          'subs_nx_department_name',
		subsd.nx_department_pick_name		'subs_nx_department_pick_name',
		subsd.nx_department_order_code		'subs_nx_department_order_code',
 		subsd.nx_department_attr_name       'subs_nx_department_attr_name',
		subsd.nx_department_settle_type      'subs_nx_department_settle_type',
		subsd.nx_department_type          'subs_nx_department_type',
		subsd.nx_department_print_name    'subs_nx_department_print_name',
		subsd.nx_department_show_weeks    'subs_nx_department_show_weeks',
		subsd.nx_department_father_id     'subs_nx_department_father_id',
		subsd.nx_department_is_group_dep  'subs_nx_department_is_group_dep',
		subsd.nx_department_dis_id        'subs_nx_department_dis_id',
		subsd.nx_department_sub_amount    'subs_nx_department_sub_amount',
		subsd.nx_department_dis_id    'subs_nx_department_dis_id',
		subsd.nx_department_join_date    'subs_nx_department_join_date',
		subsd.nx_department_pinyin    'subs_nx_department_pinyin',
		subsd.nx_department_order_total    'subs_nx_department_order_total',
		ds.gb_department_id 'gb_department_id',
		ds.gb_department_name 'gb_department_name',
		ds.gb_department_type 'gb_department_type',
		ds.gb_department_father_id 'gb_department_father_id',
		ds.gb_department_is_group_dep 'gb_department_is_group_dep',
		df.gb_department_id 'dd_gb_department_id',
		df.gb_department_name 'dd_gb_department_name'
		       from nx_distributer_pay_list as ndpl
		left join nx_department as d on d.nx_department_id = ndpl.nx_ndpl_nx_department_father_id
		left join nx_department as subsd on subsd.nx_department_id = ndpl.nx_ndpl_nx_department_id
		 left join gb_department as ds  on ds.gb_department_id  = ndpl.nx_ndpl_gb_department_id
		 left join gb_department as df   on df.gb_department_id = ndpl.nx_ndpl_gb_department_father_id                                            
		<where>
			<if test="disId != null">
				and nx_ndpl_nx_dis_id = #{disId}
			</if>
			<if test="type != null">
				and nx_ndpl_type = #{type}
			</if>
		</where>
		order by nx_distributer_pay_list_id DESC
		limit #{offset}, #{limit}

	</select>
