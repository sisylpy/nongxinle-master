			<if test="nxNdplStatus != null">`nx_ndpl_status` = #{nxNdplStatus}, </if>
			<if test="nxNdplPayDate != null">`nx_ndpl_pay_date` = #{nxNdplPayDate}, </if>
			<if test="nxNdplRestPoints != null">`nx_ndpl_rest_points` = #{nxNdplRestPoints}, </if>
			<if test="nxNdplPayMonth != null">`nx_ndpl_pay_month` = #{nxNdplPayMonth}, </if>
			<if test="nxNdplPayYear != null">`nx_ndpl_pay_year` = #{nxNdplPayYear}, </if>
			<if test="nxNdplNxDepartmentFatherId != null">`nx_ndpl_nx_department_father_id` = #{nxNdplNxDepartmentFatherId}, </if>
			<if test="nxNdplGbDepartmentFatherId != null">`nx_ndpl_gb_department_father_id` = #{nxNdplGbDepartmentFatherId}, </if>
			<if test="nxNdplNxDepartmentId != null">`nx_ndpl_nx_department_id` = #{nxNdplNxDepartmentId}, </if>
			<if test="nxNdplGbDepartmentId != null">`nx_ndpl_gb_department_id` = #{nxNdplGbDepartmentId}, </if>
			<if test="nxNdplGbDbId != null">`nx_ndpl_gb_db_id` = #{nxNdplGbDbId}, </if>
