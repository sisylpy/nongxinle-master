<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.NxCustomerUserCouponDao">

	<select id="queryObject" resultType="com.nongxinle.entity.NxCustomerUserCouponEntity">
		select * from nx_customer_user_coupon where nx_customer_user_coupon_id = #{value}
	</select>

	<insert id="save" parameterType="com.nongxinle.entity.NxCustomerUserCouponEntity"
			useGeneratedKeys="true" keyProperty="nxCustomerUserCouponId">
		insert into nx_customer_user_coupon
		<trim prefix="(" suffix=")" suffixOverrides=",">
			`nx_customer_user_coupon_id`,
			`nx_cuc_coupon_id`,
			`nx_cuc_customer_user_id`,
			`nx_cuc_share_user_id`,
			`nx_cuc_community_id`,
			`nx_cuc_status`,
			`nx_cuc_source_type`,
			`nx_cuc_source_biz_id`,
			`nx_cuc_order_id`,
			`nx_cuc_from_share_user_id`,
			`nx_cuc_share_time`,
			<if test="nxCucStartDate != null">`nx_cuc_start_date`,</if>
			<if test="nxCucStopDate != null">`nx_cuc_stop_date`,</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			#{nxCustomerUserCouponId},
			#{nxCucCouponId},
			#{nxCucCustomerUserId},
			#{nxCucShareUserId},
			#{nxCucCommunityId},
			#{nxCucStatus},
			#{nxCucSourceType},
			#{nxCucSourceBizId},
			#{nxCucOrderId},
			#{nxCucFromShareUserId},
			#{nxCucShareTime},
			<if test="nxCucStartDate != null">#{nxCucStartDate},</if>
			<if test="nxCucStopDate != null">#{nxCucStopDate},</if>
		</trim>
	</insert>

	<update id="update" parameterType="com.nongxinle.entity.NxCustomerUserCouponEntity">
		update nx_customer_user_coupon
		<set>
			<if test="nxCucCouponId != null">`nx_cuc_coupon_id` = #{nxCucCouponId}, </if>
			<if test="nxCucCustomerUserId != null">`nx_cuc_customer_user_id` = #{nxCucCustomerUserId}, </if>
			<if test="nxCucShareUserId != null">`nx_cuc_share_user_id` = #{nxCucShareUserId}, </if>
			<if test="nxCucCommunityId != null">`nx_cuc_community_id` = #{nxCucCommunityId}, </if>
			<if test="nxCucSourceType != null">`nx_cuc_source_type` = #{nxCucSourceType}, </if>
			<if test="nxCucSourceBizId != null">`nx_cuc_source_biz_id` = #{nxCucSourceBizId}, </if>
			<if test="nxCucOrderId != null">`nx_cuc_order_id` = #{nxCucOrderId}, </if>
			<if test="nxCucFromShareUserId != -99">`nx_cuc_from_share_user_id` = #{nxCucFromShareUserId}, </if>
			<if test="nxCucShareTime != null">`nx_cuc_share_time` = #{nxCucShareTime}, </if>
			<if test="nxCucStartDate != null">`nx_cuc_start_date` = #{nxCucStartDate}, </if>
			<if test="nxCucStopDate != null">`nx_cuc_stop_date` = #{nxCucStopDate}, </if>
			<if test="nxCucStatus != null">`nx_cuc_status` = #{nxCucStatus}</if>
		</set>
		where nx_customer_user_coupon_id = #{nxCustomerUserCouponId}
	</update>

	<resultMap id="customerUser" type="NxCustomerUserEntity">
		<id property="nxCuUserId" column="nx_CU_user_id"/>
		<result property="nxCuCommerceId" column="nx_CU_commerce_id"/>
		<result property="nxCuOrderTimes" column="nx_CU_order_times"/>
		<result property="nxCuWxGender" column="nx_CU_wx_gender"/>
		<result property="nxCuWxPhoneNumber" column="nx_CU_wx_phone_number"/>
		<result property="nxCuWxNickName" column="nx_CU_wx_nick_name"/>
		<result property="nxCuCommunityId" column="nx_CU_community_id"/>
		<result property="nxCuWxOpenId" column="nx_CU_wx_open_id"/>
		<result property="nxCuWxAvatarUrl" column="nx_CU_wx_avatra_url"/>
		<result property="nxCuCustomerId" column="nx_CU_customer_id"/>
	</resultMap>

	<resultMap id="coupon" type="NxCommunityCouponEntity">
		<id property="nxCommunityCouponId" column="nx_community_coupon_id"/>
		<result property="nxCommunityCouponName" column="nx_community_coupon_name"/>
		<result property="couponType" column="coupon_type"/>
		<result property="discountAmount" column="discount_amount"/>
		<result property="thresholdAmount" column="threshold_amount"/>
		<result property="scopeType" column="scope_type"/>
		<result property="scopeRefIds" column="scope_ref_ids"/>
		<result property="useChannel" column="use_channel"/>
		<result property="nxCpDownCount" column="nx_cp_down_count"/>
		<result property="nxCpUseCount" column="nx_cp_use_count"/>
		<result property="nxCpWords" column="nx_cp_words"/>
		<result property="nxCpFilePath" column="nx_cp_file_path"/>
		<result property="nxCpStartTime" column="nx_cp_start_time"/>
		<result property="nxCpStopTime" column="nx_cp_stop_time"/>
		<result property="nxCpStartDate" column="nx_cp_start_date"/>
		<result property="nxCpStopDate" column="nx_cp_stop_date"/>
		<result property="nxCpStartTimeZone" column="nx_cp_start_time_zone" jdbcType="TIMESTAMP" typeHandler="com.nongxinle.utils.LocalDateTimeTypeHandler"/>
		<result property="nxCpStopTimeZone" column="nx_cp_stop_time_zone" jdbcType="TIMESTAMP" typeHandler="com.nongxinle.utils.LocalDateTimeTypeHandler"/>
		<result property="nxCpBizPurpose" column="nx_cp_biz_purpose"/>
		<result property="nxCpClaimStrategy" column="nx_cp_claim_strategy"/>
		<result property="nxCpValidityType" column="nx_cp_validity_type"/>
		<result property="nxCpValidityDays" column="nx_cp_validity_days"/>
		<result property="nxCpStatus" column="nx_cp_status"/>
		<result property="nxCpCommunityId" column="nx_cp_community_id"/>
	</resultMap>

	<resultMap id="userCoup" type="NxCustomerUserCouponEntity">
		<id property="nxCustomerUserCouponId" column="nx_customer_user_coupon_id"/>
		<result property="nxCucCouponId" column="nx_cuc_coupon_id"/>
		<result property="nxCucStatus" column="nx_cuc_status"/>
		<result property="nxCucCustomerUserId" column="nx_cuc_customer_user_id"/>
		<result property="nxCucShareUserId" column="nx_cuc_share_user_id"/>
		<result property="nxCucFromShareUserId" column="nx_cuc_from_share_user_id"/>
		<result property="nxCucSourceType" column="nx_cuc_source_type"/>
		<result property="nxCucSourceBizId" column="nx_cuc_source_biz_id"/>
		<result property="nxCucOrderId" column="nx_cuc_order_id"/>
		<result property="nxCucCommunityId" column="nx_cuc_community_id"/>
		<result property="nxCucShareTime" column="nx_cuc_share_time"/>
		<result property="nxCucStartDate" column="nx_cuc_start_date"/>
		<result property="nxCucStopDate" column="nx_cuc_stop_date"/>
		<association property="nxCommunityCouponEntity" resultMap="coupon"/>
		<association property="shareUser" resultMap="customerUser"/>
	</resultMap>

	<select id="queryUserCouponListByParams" resultMap="userCoup">
		select ncuc.*,
		       ncc.nx_community_coupon_id as nx_community_coupon_id,
		       ncc.nx_community_coupon_name as nx_community_coupon_name,
		       ncc.coupon_type as coupon_type,
		       ncc.discount_amount as discount_amount,
		       ncc.threshold_amount as threshold_amount,
		       ncc.scope_type as scope_type,
		       ncc.scope_ref_ids as scope_ref_ids,
		       ncc.use_channel as use_channel,
		       ncc.nx_cp_words as nx_cp_words,
		       COALESCE(ncuc.nx_cuc_start_date, ncc.nx_cp_start_date) as nx_cp_start_date,
		       COALESCE(ncuc.nx_cuc_stop_date, ncc.nx_cp_stop_date) as nx_cp_stop_date,
		       ncc.nx_cp_file_path as nx_cp_file_path,
		       ncc.nx_cp_biz_purpose as nx_cp_biz_purpose,
		       ncc.nx_cp_claim_strategy as nx_cp_claim_strategy,
		       ncc.nx_cp_status as nx_cp_status,
		       ncc.nx_cp_community_id as nx_cp_community_id
		from nx_customer_user_coupon as ncuc
		left join nx_community_coupon as ncc on ncuc.nx_cuc_coupon_id = ncc.nx_community_coupon_id
		left join nx_customer_user as ncu on ncu.nx_CU_user_id = ncuc.nx_cuc_from_share_user_id
		<where>
			<if test="userId != null">
				and nx_cuc_customer_user_id = #{userId}
			</if>
			<if test="shareUserId != null and shareUserId == 1 ">
				and nx_cuc_share_user_id is not null
			</if>
			<if test="shareUserId != null and shareUserId == 0">
				and nx_cuc_share_user_id is null
			</if>
			<if test="fromShareUserId != null and fromShareUserId == 0">
				and nx_cuc_from_share_user_id is null
			</if>
			<if test="status != null">
				and nx_cuc_status = #{status}
			</if>
			<if test="stopDate != null">
				and ncc.nx_cp_stop_date &lt;= #{stopDate}
			</if>
			<if test="stopTime != null">
				and ncc.nx_cp_stop_time_zone &gt;= #{stopTime}
			</if>
			<if test="nowTime != null">
				and ncc.nx_cp_stop_time_zone &lt;= #{nowTime}
			</if>
			<if test="dayuStatus != null">
				and nx_cuc_status &gt; #{dayuStatus}
			</if>
			<if test="xiaoyuStatus != null">
				and nx_cuc_status &lt; #{xiaoyuStatus}
			</if>
			<if test="coupId != null">
				and nx_cuc_coupon_id = #{coupId}
			</if>
			<if test="commId != null">
				and nx_cuc_community_id = #{commId}
			</if>
			<if test="sourceType != null">
				and nx_cuc_source_type = #{sourceType}
			</if>
			<if test="sourceBizId != null">
				and nx_cuc_source_biz_id = #{sourceBizId}
			</if>
		</where>
		order by ncc.nx_cp_start_date
	</select>

	<select id="queryUserCouponDetail" resultMap="userCoup">
		select ncuc.*,
		       ncc.nx_community_coupon_id as nx_community_coupon_id,
		       ncc.nx_community_coupon_name as nx_community_coupon_name,
		       ncc.coupon_type as coupon_type,
		       ncc.discount_amount as discount_amount,
		       ncc.threshold_amount as threshold_amount,
		       ncc.scope_type as scope_type,
		       ncc.scope_ref_ids as scope_ref_ids,
		       ncc.use_channel as use_channel,
		       ncc.nx_cp_words as nx_cp_words,
		       COALESCE(ncuc.nx_cuc_start_date, ncc.nx_cp_start_date) as nx_cp_start_date,
		       COALESCE(ncuc.nx_cuc_stop_date, ncc.nx_cp_stop_date) as nx_cp_stop_date,
		       ncc.nx_cp_file_path as nx_cp_file_path,
		       ncc.nx_cp_biz_purpose as nx_cp_biz_purpose,
		       ncc.nx_cp_claim_strategy as nx_cp_claim_strategy,
		       ncc.nx_cp_status as nx_cp_status
		from nx_customer_user_coupon as ncuc
		left join nx_community_coupon as ncc on ncuc.nx_cuc_coupon_id = ncc.nx_community_coupon_id
		where ncuc.nx_customer_user_coupon_id = #{id}
	</select>

	<select id="queryUserCouponCount" resultType="java.lang.Integer">
		select count(*) from nx_customer_user_coupon
		<where>
			<if test="userId != null">
				and nx_cuc_customer_user_id = #{userId}
			</if>
			<if test="shareUserId != null and shareUserId == 1 ">
				and nx_cuc_share_user_id is not null
			</if>
			<if test="shareUserId != null and shareUserId == 0">
				and nx_cuc_share_user_id is null
			</if>
			<if test="status != null">
				and nx_cuc_status = #{status}
			</if>
			<if test="xiaoyuStatus != null">
				and nx_cuc_status &lt; #{xiaoyuStatus}
			</if>
			<if test="dayuStatus != null">
				and nx_cuc_status &gt; #{dayuStatus}
			</if>
			<if test="coupId != null">
				and nx_cuc_coupon_id = #{coupId}
			</if>
			<if test="commId != null">
				and nx_cuc_community_id = #{commId}
			</if>
		</where>
	</select>

</mapper>
