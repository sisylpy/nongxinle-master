<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.NxDisRouteUnassignedStopDao">

    <select id="queryByPlanId" resultType="com.nongxinle.entity.NxDisRouteUnassignedStopEntity">
        select * from nx_dis_route_unassigned_stop
        where nx_drus_plan_id = #{value}
        order by nx_drus_id
    </select>

    <insert id="save" parameterType="com.nongxinle.entity.NxDisRouteUnassignedStopEntity"
            useGeneratedKeys="true" keyProperty="nxDrusId">
        insert into nx_dis_route_unassigned_stop
        (`nx_drus_plan_id`, `nx_drus_department_id`, `nx_drus_department_name`,
         `nx_drus_order_count`, `nx_drus_reason`)
        values
        (#{nxDrusPlanId}, #{nxDrusDepartmentId}, #{nxDrusDepartmentName},
         #{nxDrusOrderCount}, #{nxDrusReason})
    </insert>

    <delete id="deleteByPlanId">
        delete from nx_dis_route_unassigned_stop where nx_drus_plan_id = #{value}
    </delete>
</mapper>
