    <select id="queryGbDepBillsByParams" resultMap="billWithGbDepAndApplys">
        select * from nx_department_bill as db
        left join nx_department_order_history as dor on dor.nx_DO_bill_id = db.nx_department_bill_id
        left join nx_distributer_goods as dg on dg.nx_distributer_goods_id = dor.nx_DO_dis_goods_id
        left join gb_department as gd on gd.gb_department_id = db.nx_DB_gb_dep_id
        left join nx_restraunt as nr on nr.nx_restraunt_id = db.nx_DB_nx_restraunt_id
        <where>
            <if test="gbDisId != null">
              and  db.nx_DB_gb_dis_id = #{gbDisId}
            </if>
            <if test="disId != null">
                and db.nx_DB_dis_id = #{disId}
            </if>
            <if test="depId != null">
               and  db.nx_DB_dep_id = #{depId}
            </if>
            <if test="depFatherId != null">
               and db.nx_DB_dep_father_id = #{depFatherId}
            </if>
            <if test="dayuStatus != null">
                and db.nx_DB_status &gt; #{dayuStatus}
            </if>
            <if test="status != null">
                and db.nx_DB_status &lt; #{status}
            </if>
            <if test="equalStatus != null ">
                and db.nx_DB_status = #{equalStatus}
            </if>
            <if test="month != null ">
                and db.nx_DB_month = #{month}
            </if>
            <if test="gbDisId != null ">
                and db.nx_DB_gb_dis_id = #{gbDisId}
            </if>
            <if test="startDate != null ">
                and db.nx_DB_date &gt;= #{startDate}
            </if>
            <if test="stopDate != null ">
                and db.nx_DB_date &lt;= #{stopDate}
            </if>
            <if test="nxCommId != null ">
                and db.nx_DB_nx_community_id = #{nxCommId}
            </if>

        </where>
        order by nx_DB_time DESC
    </select>
