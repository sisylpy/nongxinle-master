<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nongxinle.dao.NxCommunityCouponDao">

	<resultMap id="coupon" type="NxCommunityCouponEntity">
		<id property="nxCommunityCouponId" column="nx_community_coupon_id"/>
		<result property="nxCommunityCouponName" column="nx_community_coupon_name"/>
		<result property="couponType" column="coupon_type"/>
		<result property="discountAmount" column="discount_amount"/>
		<result property="thresholdAmount" column="threshold_amount"/>
		<result property="scopeType" column="scope_type"/>
		<result property="scopeRefIds" column="scope_ref_ids"/>
		<result property="useChannel" column="use_channel"/>
		<result property="nxCpDownCount" column="nx_cp_down_count"/>
		<result property="nxCpUseCount" column="nx_cp_use_count"/>
		<result property="nxCpFilePath" column="nx_cp_file_path"/>
		<result property="nxCpStartTime" column="nx_cp_start_time"/>
		<result property="nxCpStopTime" column="nx_cp_stop_time"/>
		<result property="nxCpStartDate" column="nx_cp_start_date"/>
		<result property="nxCpStopDate" column="nx_cp_stop_date"/>
		<result property="nxCpStartTimeZone" column="nx_cp_start_time_zone" jdbcType="TIMESTAMP" typeHandler="com.nongxinle.utils.LocalDateTimeTypeHandler"/>
		<result property="nxCpStopTimeZone" column="nx_cp_stop_time_zone" jdbcType="TIMESTAMP" typeHandler="com.nongxinle.utils.LocalDateTimeTypeHandler"/>
		<result property="nxCpBizPurpose" column="nx_cp_biz_purpose"/>
		<result property="nxCpClaimStrategy" column="nx_cp_claim_strategy"/>
		<result property="nxCpValidityType" column="nx_cp_validity_type"/>
		<result property="nxCpValidityDays" column="nx_cp_validity_days"/>
		<result property="nxCpStatus" column="nx_cp_status"/>
		<result property="nxCpWords" column="nx_cp_words"/>
		<result property="nxCpCommunityId" column="nx_cp_community_id"/>
	</resultMap>

	<select id="queryCouponListByParams" resultMap="coupon">
		select * from nx_community_coupon
		<where>
			<if test="commId != null">
				and nx_cp_community_id = #{commId}
			</if>
			<if test="status != null">
				and nx_cp_status = #{status}
			</if>
		</where>
	</select>

	<select id="queryObject" resultMap="coupon">
		select * from nx_community_coupon where nx_community_coupon_id = #{value}
	</select>

	<select id="queryCustomerShowCoupon" resultMap="coupon">
		select * from nx_community_coupon
		<where>
			<if test="commId != null">
				and nx_cp_community_id = #{commId}
			</if>
			<if test="status != null">
				and nx_cp_status = #{status}
			</if>
			<if test="xiaoyuStatus != null">
				and nx_cp_status &lt; #{xiaoyuStatus}
			</if>
			<if test="stopDate != null">
				and nx_cp_stop_date &lt;= #{stopDate}
			</if>
			<if test="stopTime != null">
				and nx_cp_stop_time_zone &lt; #{stopTime}
			</if>
			<if test="dayuStopDate != null">
				and nx_cp_stop_date &gt;= #{dayuStopDate}
			</if>
			<if test="dayuStopTime != null">
				and nx_cp_stop_time_zone &gt; #{dayuStopTime}
			</if>
			<if test="publicActiveOnly != null and publicActiveOnly == true">
				and (nx_cp_claim_strategy is null or nx_cp_claim_strategy = 'public_active')
			</if>
			<if test="claimStrategy != null">
				and nx_cp_claim_strategy = #{claimStrategy}
			</if>
		</where>
	</select>

	<select id="queryCouponDetail" resultMap="coupon">
		select * from nx_community_coupon
		<where>
			<if test="id != null">
				and nx_community_coupon_id = #{id}
			</if>
			<if test="commId != null">
				and nx_cp_community_id = #{commId}
			</if>
			<if test="status != null">
				and nx_cp_status = #{status}
			</if>
		</where>
	</select>

	<insert id="save" parameterType="com.nongxinle.entity.NxCommunityCouponEntity"
			useGeneratedKeys="true" keyProperty="nxCommunityCouponId">
		insert into nx_community_coupon
		(
			`nx_community_coupon_id`,
			`nx_community_coupon_name`,
			`coupon_type`,
			`discount_amount`,
			`threshold_amount`,
			`scope_type`,
			`scope_ref_ids`,
			`use_channel`,
			`nx_cp_stop_time`,
			`nx_cp_start_time`,
			`nx_cp_words`,
			`nx_cp_file_path`,
			`nx_cp_community_id`,
			`nx_cp_biz_purpose`,
			`nx_cp_claim_strategy`,
			`nx_cp_validity_type`,
			`nx_cp_validity_days`,
			`nx_cp_status`,
			`nx_cp_start_time_zone`,
			`nx_cp_stop_time_zone`,
			`nx_cp_start_date`,
			`nx_cp_stop_date`,
			`nx_cp_down_count`,
			`nx_cp_use_count`
		)
		values
		(
			#{nxCommunityCouponId},
			#{nxCommunityCouponName},
			#{couponType},
			#{discountAmount},
			#{thresholdAmount},
			#{scopeType},
			#{scopeRefIds},
			#{useChannel},
			#{nxCpStopTime},
			#{nxCpStartTime},
			#{nxCpWords},
			#{nxCpFilePath},
			#{nxCpCommunityId},
			#{nxCpBizPurpose},
			#{nxCpClaimStrategy},
			#{nxCpValidityType},
			#{nxCpValidityDays},
			#{nxCpStatus},
			#{nxCpStartTimeZone},
			#{nxCpStopTimeZone},
			#{nxCpStartDate},
			#{nxCpStopDate},
			#{nxCpDownCount},
			#{nxCpUseCount}
		)
	</insert>

	<update id="update" parameterType="com.nongxinle.entity.NxCommunityCouponEntity">
		update nx_community_coupon
		<set>
			<if test="nxCommunityCouponName != null">`nx_community_coupon_name` = #{nxCommunityCouponName}, </if>
			<if test="couponType != null">`coupon_type` = #{couponType}, </if>
			<if test="discountAmount != null">`discount_amount` = #{discountAmount}, </if>
			<if test="thresholdAmount != null">`threshold_amount` = #{thresholdAmount}, </if>
			<if test="scopeType != null">`scope_type` = #{scopeType}, </if>
			<if test="scopeRefIds != null">`scope_ref_ids` = #{scopeRefIds}, </if>
			<if test="useChannel != null">`use_channel` = #{useChannel}, </if>
			<if test="nxCpStopTime != null">`nx_cp_stop_time` = #{nxCpStopTime}, </if>
			<if test="nxCpStartTime != null">`nx_cp_start_time` = #{nxCpStartTime}, </if>
			<if test="nxCpWords != null">`nx_cp_words` = #{nxCpWords}, </if>
			<if test="nxCpFilePath != null">`nx_cp_file_path` = #{nxCpFilePath}, </if>
			<if test="nxCpCommunityId != null">`nx_cp_community_id` = #{nxCpCommunityId}, </if>
			<if test="nxCpBizPurpose != null">`nx_cp_biz_purpose` = #{nxCpBizPurpose}, </if>
			<if test="nxCpClaimStrategy != null">`nx_cp_claim_strategy` = #{nxCpClaimStrategy}, </if>
			<if test="nxCpValidityType != null">`nx_cp_validity_type` = #{nxCpValidityType}, </if>
			<if test="nxCpValidityDays != null">`nx_cp_validity_days` = #{nxCpValidityDays}, </if>
			<if test="nxCpStartTimeZone != null">`nx_cp_start_time_zone` = #{nxCpStartTimeZone}, </if>
			<if test="nxCpStopTimeZone != null">`nx_cp_stop_time_zone` = #{nxCpStopTimeZone}, </if>
			<if test="nxCpStartDate != null">`nx_cp_start_date` = #{nxCpStartDate}, </if>
			<if test="nxCpStopDate != null">`nx_cp_stop_date` = #{nxCpStopDate}, </if>
			<if test="nxCpDownCount != null">`nx_cp_down_count` = #{nxCpDownCount}, </if>
			<if test="nxCpUseCount != null">`nx_cp_use_count` = #{nxCpUseCount}, </if>
			<if test="nxCpStatus != null">`nx_cp_status` = #{nxCpStatus}</if>
		</set>
		where nx_community_coupon_id = #{nxCommunityCouponId}
	</update>

	<delete id="delete">
		delete from nx_community_coupon where nx_community_coupon_id = #{value}
	</delete>

	<delete id="deleteBatch">
		delete from nx_community_coupon where nx_community_coupon_id in
		<foreach item="nxCommunityCouponId" collection="array" open="(" separator="," close=")">
			#{nxCommunityCouponId}
		</foreach>
	</delete>

</mapper>
