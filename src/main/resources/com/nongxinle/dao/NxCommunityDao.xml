		)
	</insert>

	<update id="update" parameterType="com.nongxinle.entity.NxCommunityEntity">
		update nx_community
		<set>
			<if test="nxCommunityName != null">`nx_community_name` = #{nxCommunityName}, </if>
			<if test="nxCommunityRouteId != null">`nx_community_route_id` = #{nxCommunityRouteId}, </if>
			<if test="nxCommunityLng != null">`nx_community_lng` = #{nxCommunityLng}, </if>
			<if test="nxCommunityLat != null">`nx_community_lat` = #{nxCommunityLat}, </if>
			<if test="nxCommunityCommerceId != null">`nx_community_commerce_id` = #{nxCommunityCommerceId}, </if>
			<if test="nxCommunityPolygon != null">`nx_community_polygon` = #{nxCommunityPolygon}, </if>
			<if test="nxCommunityRegion != null">`nx_community_region` = #{nxCommunityRegion}, </if>
			<if test="nxCommunityDeliveryAddress != null">`nx_community_delivery_address` = #{nxCommunityDeliveryAddress}, </if>
			<if test="nxCommunityType != null">`nx_community_type` = #{nxCommunityType}, </if>
			<if test="nxCommunityWxFile != null">`nx_community_wx_file` = #{nxCommunityWxFile}, </if>
			<if test="nxCommunityOpenTime != null">`nx_community_open_time` = #{nxCommunityOpenTime}, </if>
			<if test="nxCommunityCloseTime != null">`nx_community_close_time` = #{nxCommunityCloseTime}, </if>
			<if test="nxCommunityDoorFile != null">`nx_community_door_file` = #{nxCommunityDoorFile}, </if>
			<if test="nxCommunityPrePrintTimes != null">`nx_community_pre_print_times` = #{nxCommunityPrePrintTimes}, </if>
			<if test="nxCommunityDeliveryMixSubtotal != null">`nx_community_delivery_mix_subtotal` = #{nxCommunityDeliveryMixSubtotal}, </if>
			<if test="nxCommunityDeliveryFeeFreeDistance != null">`nx_community_delivery_fee_free_distance` = #{nxCommunityDeliveryFeeFreeDistance}, </if>
			<if test="nxCommunityDeliveryPayPercent != null">`nx_community_delivery_pay_percent` = #{nxCommunityDeliveryPayPercent}, </if>
			<if test="nxCommunityDeliveryPayMaxFee != null">`nx_community_delivery_pay_max_fee` = #{nxCommunityDeliveryPayMaxFee}, </if>
			<if test="nxCommunitySysCityId != null">`nx_community_sys_city_id` = #{nxCommunitySysCityId}, </if>
			<if test="nxCommunitySysBusinessAreaId != null">`nx_community_sys_business_area_id` = #{nxCommunitySysBusinessAreaId}, </if>
			<if test="nxCommunitySysDistrictId != null">`nx_community_sys_district_id` = #{nxCommunitySysDistrictId}, </if>
			<if test="nxCommunitySysProvinceId != null">`nx_community_sys_province_id` = #{nxCommunitySysProvinceId}, </if>
			<if test="nxCommunityBillPrintSn != null">`nx_community_bill_print_sn` = #{nxCommunityBillPrintSn}, </if>
			<if test="nxCommunityBusinessPhone != null">`nx_community_business_phone` = #{nxCommunityBusinessPhone}, </if>
			<if test="nxCommunityLocation != null">
				`nx_community_location` =
				ST_GeomFromText(CONCAT('POINT(', #{nxCommunityLng}, ' ', #{nxCommunityLat}, ')'))
			</if>
		</set>
		where nx_community_id = #{nxCommunityId}
	</update>



