	<delete id="delete">
		delete from nx_community where nx_community_id = #{value}
	</delete>
	
	<delete id="deleteBatch">
		delete from nx_community where nx_community_id in 
		<foreach item="nxCommunityId" collection="array" open="(" separator="," close=")">
			#{nxCommunityId}
		</foreach>
	</delete>

